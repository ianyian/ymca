type SessionUser = { id: string; email: string; displayName: string | null };
type Workspace = { id: string; name: string; slug: string; role: string };
type PageNode = {
  id: string; title: string; icon: string | null; version: number;
  parentPageId: string | null; position: string | null; deletedAt: string | null;
  children: PageNode[];
};
type PageDetail = {
  id: string; title: string; icon: string | null; content: Record<string, unknown>;
  version: number; isPublished: boolean; publishedAt: string | null;
  workspaceId: string; deletedAt: string | null;
};
type Revision = { id: string; version: number; createdBy: string | null; createdAt: string };

