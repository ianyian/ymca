NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=4000
# Local Postgres example.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ymca
# Direct (non-pooled) connection used by Prisma Migrate. For local Postgres this
# is the same as DATABASE_URL; for Neon it must be the DIRECT endpoint (no -pooler).
DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ymca
#
# Neon example (pooled app connection + direct migration connection):
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require&pgbouncer=true
# DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require
#
# Neon-via-local-TLS-proxy demo (legacy):
# DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5433/ymca?sslmode=disable
# NEON_PROXY_HOST=ep-xxxxxx-xxxxxx.us-east-2.aws.neon.tech
# NEON_PROXY_LOCAL_PORT=5433
BCRYPT_ROUNDS=12
SESSION_TTL_DAYS=30
# Public URL of the web app — used in password-reset emails and published-page
# links. MUST be set in production (defaults to http://localhost:5173).
APP_URL=http://localhost:5173
# Comma-separated allowlist of browser origins for CORS. Leave unset to reflect
# the request origin (dev). In production set to your web app origin(s), e.g.:
# CORS_ORIGINS=https://your-web-app.onrender.com
