generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Direct (non-pooled) connection for migrations. When DATABASE_URL points at
  // the Neon pooler (PgBouncer), migrations must use a direct connection.
  directUrl = env("DIRECT_DATABASE_URL")
}

enum WorkspaceRole {
  WorkspaceOwner
  WorkspaceAdmin
  WorkspaceMember
  WorkspaceGuest
}

enum PageRole {
  Owner
  Editor
  Viewer
}

/// Global, application-wide role for a user. This is a lookup table (not an enum)
/// so new roles (viewer, debugger, superUser, ...) can be added by inserting a row,
/// with no schema migration. `rank` gives a coarse privilege ordering for future use.
/// Seeded ids are stable: admin = 1, user = 2.
model AppRole {
  id           Int      @id @default(autoincrement()) @db.SmallInt
  key          String   @unique @db.VarChar(32)
  label        String   @db.VarChar(64)
  description  String?
  rank         Int      @default(0)
  isAssignable Boolean  @default(true)
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)
  users        User[]
}

model User {
  id              String            @id @default(uuid()) @db.Uuid
  email           String            @unique
  passwordHash    String
  displayName     String?
  language        String            @default("en")
  // Global app role. DB default 2 ("user"); existing rows backfilled to 1 ("admin").
  appRoleId       Int               @default(2) @db.SmallInt
  createdAt       DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime          @updatedAt @db.Timestamptz(6)
  appRole         AppRole           @relation(fields: [appRoleId], references: [id], onDelete: Restrict)
  sessions        Session[]
  workspacesOwned Workspace[]            @relation("WorkspaceOwner")
  memberships     WorkspaceMember[]
  pagesCreated    Page[]                 @relation("PageCreator")
  pagePermissions PagePermission[]       @relation("PermissionGrantedTo")
  invitesCreated  InviteToken[]          @relation("InviteCreator")
  passwordResets  PasswordResetToken[]
  activityEvents  ActivityEvent[]

  @@index([appRoleId])
}

/// Append-only activity log powering the CoMa monitoring dashboard (API-call volume,
/// active-user counts). Rows are written via a batched, in-memory buffer to keep write
/// amplification low at scale. `path` stores the normalized route pattern (e.g.
/// "/pages/:id") rather than the raw URL, to bound cardinality. Prune/rollup for very
/// long retention is a future concern; indexes are tuned for recent-window queries.
model ActivityEvent {
  id         BigInt   @id @default(autoincrement())
  userId     String?  @db.Uuid
  method     String   @db.VarChar(8)
  path       String   @db.VarChar(256)
  statusCode Int      @db.SmallInt
  durationMs Int?
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId, createdAt])
}

model Session {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @db.Uuid
  tokenHash     String    @unique
  csrfToken     String
  userAgent     String?
  ipAddress     String?
  expiresAt     DateTime  @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  lastSeenAt    DateTime  @default(now()) @db.Timestamptz(6)
  invalidatedAt DateTime? @db.Timestamptz(6)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Workspace {
  id        String            @id @default(uuid()) @db.Uuid
  name      String
  slug      String            @unique
  ownerId   String            @db.Uuid
  createdAt DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt DateTime          @updatedAt @db.Timestamptz(6)
  owner     User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  members   WorkspaceMember[]
  pages     Page[]
  invites   InviteToken[]
}

model WorkspaceMember {
  id          String        @id @default(uuid()) @db.Uuid
  workspaceId String        @db.Uuid
  userId      String        @db.Uuid
  role        WorkspaceRole
  invitedById String?       @db.Uuid
  createdAt   DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime      @updatedAt @db.Timestamptz(6)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model Page {
  id            String           @id @default(uuid()) @db.Uuid
  workspaceId   String           @db.Uuid
  parentPageId  String?          @db.Uuid
  creatorId     String           @db.Uuid
  title         String           @default("Untitled")
  icon          String?
  coverImageUrl String?
  tags          String[]         @default([])
  content       Json             @default("{}") @db.JsonB
  version       Int              @default(1)
  isPublished   Boolean          @default(false)
  publishedAt   DateTime?        @db.Timestamptz(6)
  publishToken  String?          @unique
  publishTheme  String           @default("muji")
  deletedAt     DateTime?        @db.Timestamptz(6)
  createdAt     DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime         @updatedAt @db.Timestamptz(6)
  workspace     Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator       User             @relation("PageCreator", fields: [creatorId], references: [id], onDelete: Restrict)
  parentPage    Page?            @relation("PageHierarchy", fields: [parentPageId], references: [id], onDelete: SetNull)
  childPages    Page[]           @relation("PageHierarchy")
  revisions     PageRevision[]
  permissions   PagePermission[]
  attachments   PageAttachment[]

  @@index([parentPageId])
  @@index([workspaceId, deletedAt])
  @@index([tags], type: Gin)
}

model PageRevision {
  id        String   @id @default(uuid()) @db.Uuid
  pageId    String   @db.Uuid
  version   Int
  snapshot  Json     @db.JsonB
  createdBy String?  @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, createdAt])
}

model PagePermission {
  id             String         @id @default(uuid()) @db.Uuid
  pageId         String         @db.Uuid
  userId         String?        @db.Uuid
  workspaceRole  WorkspaceRole?
  pageRole       PageRole
  isExplicitDeny Boolean        @default(false)
  grantedById    String?        @db.Uuid
  createdAt      DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime       @updatedAt @db.Timestamptz(6)
  page           Page           @relation(fields: [pageId], references: [id], onDelete: Cascade)
  user           User?          @relation("PermissionGrantedTo", fields: [userId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@index([userId])
}

model InviteToken {
  id          String        @id @default(uuid()) @db.Uuid
  workspaceId String        @db.Uuid
  email       String?
  role        WorkspaceRole
  token       String        @unique
  expiresAt   DateTime      @db.Timestamptz(6)
  usedAt      DateTime?     @db.Timestamptz(6)
  createdById String        @db.Uuid
  createdAt   DateTime      @default(now()) @db.Timestamptz(6)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy   User          @relation("InviteCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([workspaceId])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @db.Uuid
  token     String    @unique
  expiresAt DateTime  @db.Timestamptz(6)
  usedAt    DateTime? @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PageAttachment {
  id           String   @id @default(uuid()) @db.Uuid
  pageId       String   @db.Uuid
  filename     String
  originalName String
  mimetype     String
  size         Int
  filePath     String   @default("")
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  page         Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
}
