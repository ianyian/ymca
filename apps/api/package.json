{
  "name": "@ymca/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "pnpm prisma:generate && tsc -p tsconfig.json",
    "postinstall": "pnpm prisma:generate",
    "start": "node dist/index.js",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:unit": "node --experimental-strip-types --test tests/unit/**/*.test.ts",
    "test:integration": "node --import tsx/esm --test tests/integration/**/*.test.ts",
    "lint": "echo \"api lint pending\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@prisma/client": "^6.12.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.6.1",
    "fastify": "^5.4.0",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "prisma": "^6.12.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
